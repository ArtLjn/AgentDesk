# AgentDesk 多 Agent 工单处理系统配置
# 配置加载优先级（高 → 低）：环境变量 > .env 文件 > 本文件 (config.yaml)
# 字段名与 src/multi_agent_system/config.py::Settings 完全对应，扁平结构零侵入。
#
# 使用方法：
#   cp config.yaml.example config.yaml
#   填入真实凭据后即可运行；config.yaml 已 gitignore，不会提交到仓库。

# ---------------------------------------------------------------------------
# LLM (Chat) — 腾讯云 dfm-openai-proxy；Embedding — Google 免费在线
# ---------------------------------------------------------------------------
llm_base_url: "http://43.1xxxxx74:9000/v1"
llm_api_key: "REPLACE_WITH_REAL_LLM_TOKEN"
llm_model: "qwen3.6-flash"

embedding_base_url: "https://generativelanguage.googleapis.com/v1beta"
embedding_api_key: "REPLACE_WITH_REAL_EMBEDDING_KEY"
embedding_model: "gemini-embedding-001"
embedding_dim: 3072

# ---------------------------------------------------------------------------
# 模型路由（按用途分派）+ 兜底
# ---------------------------------------------------------------------------
model_routes:
  classify: "qwen3.6-flash"
  process:  "qwen3.6-flash"
  review:   "qwen3.6-flash"
  report:   "qwen3.6-flash"
  default:  "qwen3.6-flash"
fallback_model: "qwen3.6-flash"

# ---------------------------------------------------------------------------
# Qdrant 向量库 — 腾讯云生产机部署（启用 api_key auth）
# ---------------------------------------------------------------------------
qdrant_url: "http://43.xxxxxx.74:6333"
qdrant_api_key: "REPLACE_WITH_REAL_QDRANT_KEY"
qdrant_collection: "knowledge_base"
qdrant_batch_size: 100        # upsert 批量大小
qdrant_top_k: 3               # 检索工具默认 top_k
qdrant_score_threshold: 0.5   # 检索工具默认分数阈值

# ---------------------------------------------------------------------------
# 文档分块（RAG ingestion）
# ---------------------------------------------------------------------------
chunk_size: 512
chunk_overlap: 64

# ---------------------------------------------------------------------------
# LLM 缓存（cachetools LRUCache）
# ---------------------------------------------------------------------------
cache_enabled: true
cache_max_size: 512
cache_ttl: 300                # 秒

# ---------------------------------------------------------------------------
# 上下文窗口管理
# ---------------------------------------------------------------------------
context_max_messages: 20
context_summary_max_tokens: 200

# ---------------------------------------------------------------------------
# ReAct 循环 / 重试 / 并发 / 阈值
# ---------------------------------------------------------------------------
max_react_iterations: 10
max_retries: 3
retry_backoff_base: 2.0
max_concurrency: 5
review_threshold: 0.7
checkpoint_ttl: 86400         # 秒，24h

# ---------------------------------------------------------------------------
# 人工审核工作台
# ---------------------------------------------------------------------------
# review_timeout_threshold：审核超时阈值（秒），仅前端"超时"提示用，后端不强制 SLA
# ai_suggestion_high_confidence_threshold：AI 建议高置信度阈值，前端高亮推荐用
review_timeout_threshold: 1800
ai_suggestion_high_confidence_threshold: 0.7

# ---------------------------------------------------------------------------
# 默认采样温度（仅作记录；各 Agent 仍显式传参，后续可统一接入）
# ---------------------------------------------------------------------------
llm_temperature: 0.1

# ---------------------------------------------------------------------------
# HTTP 客户端默认超时（影响 knowledge_search.requests 调用）
# ---------------------------------------------------------------------------
http_timeout: 30              # 秒

# ---------------------------------------------------------------------------
# 数据库 / 存储
# ---------------------------------------------------------------------------
# SQLAlchemy 异步 URL（MySQL），格式：
#   mysql+aiomysql://user:password@host:port/dbname?charset=utf8mb4
database_url: "mysql+aiomysql://REPLACE_USER:REPLACE_PASSWORD@REPLACE_HOST:3306/REPLACE_DB?charset=utf8mb4"

# ---------------------------------------------------------------------------
# 可观测性
# ---------------------------------------------------------------------------
trace_max_history: 1000

# ---------------------------------------------------------------------------
# API 服务
# ---------------------------------------------------------------------------
api_host: "0.0.0.0"
api_port: 9001

# ---------------------------------------------------------------------------
# 鉴权（公网部署必填）
# ---------------------------------------------------------------------------
# auth_enabled=true 时，除 /health /metrics /prometheus /api/auth/login 外所有路径都需登录
# 密码哈希生成：python scripts/hash_password.py
auth_enabled: true
auth_username: "admin"
auth_password_hash: "REPLACE_WITH_BCRYPT_HASH"
auth_session_secret: "REPLACE_WITH_RANDOM_32_CHAR_STRING"
